# RAGSpine documentation website — environment.
#
# This is a STATIC site (Next.js `output: 'export'`, deployed to Cloudflare Pages).
# It calls no LLM / embedding / vector store and has NO runtime secrets — nothing
# here is read at request time. The only variable is a build-time public base URL
# used for canonical links / OG image absolute URLs.

NEXT_PUBLIC_SITE_URL=https://rag-spine.org
